<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="../Launcher.props" />

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <PublishAot>true</PublishAot>
    <TargetName>Final Frontier Launcher</TargetName>
    <ApplicationIcon>../SS14.Launcher/Assets/icon.ico</ApplicationIcon>
    <AssemblyTitle>Final Frontier Launcher</AssemblyTitle>
    <Product>Final Frontier Launcher</Product>
    <Description>Launcher for The Final Frontier Space Station 14 server.</Description>
    <LangVersion>12</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <!-- Make AOT small -->
    <OptimizationPreference>Size</OptimizationPreference>
    <StackTraceSupport>false</StackTraceSupport>
    <InvariantGlobalization>true</InvariantGlobalization>
    <UseSystemResourceKeys>true</UseSystemResourceKeys>

    <!-- work around https://github.com/dotnet/runtime/issues/122079 -->
    <EnableSourceLink>false</EnableSourceLink>
  </PropertyGroup>

  <ItemGroup>
    <PackageVersion Remove="Microsoft.NET.ILLink.Tasks" />
  </ItemGroup>
</Project>
